    {
      "name": "7. E-Commerce \u2014 Orders",
      "description": "Requires Bearer auth. Checkout uses an Idempotency-Key header to prevent duplicate orders.",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}",
                "description": "Unique UUID per checkout attempt. Postman generates this dynamically.",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"shippingAddress\": {\n        \"street\": \"123 Nile Street\",\n        \"city\": \"Cairo\",\n        \"zipCode\": \"11511\",\n        \"country\": \"Egypt\"\n    },\n    \"paymentMethod\": \"CASH_ON_DELIVERY\"\n}",
